# Q6 Month-wise Total revenue

select date_format(date,'%M') as `Month`,round(sum(total),0) as Total_Revenue
from walmart
group by month(date),`Month`
order by month(date);

# Q7 Year-wise Total revenue

select date_format(date,'%Y') as `Year`,round(sum(total),0) as Total_Revenue
from walmart
group by date_format(date,'%Y')
order by `Year` asc;

# Q8 How many transactions occur in each shift (Morning, Afternoon, Evening) across branches?

with cte as (SELECT *, 
(Case when hour(time)<12 Then 'Morning'  
	when hour(time) between 12 and 17 Then 'Afternoon'
    else 'Evening'
end) as Shift_time
from walmart)

select Shift_time,count(*) as Number_of_Customers
from cte
group by Shift_time;


# Q9 year-wise total users

select date_format(date,'%Y') as `Year`,count(invoice_id) as Total_Users
from walmart
group by date_format(date,'%Y')
order by `Year` asc;

